<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
    <link rel="stylesheet" href="./css/styles.css">
</head>
<body class="bg-blue-950 flex justify-center items-center h-screen">
    <main class="border-purple-600 border-2 shadow-fuchsia-600 shadow-lg bg-indigo-900 m-0 p-10 w-1/2 min-w-85 max-w-156 rounded-md">
        <div class="flex justify-around items-start flex-wrap">
            <div>
                <h1 class="text-center text-white">Log In</h1>
                <div class="input_div" id="logIn">
                    <input type="text" name="username" placeholder="Username" class="input">
                    <input type="text" name="password" placeholder="Password" class="input">
                    <button id="logInBtn" class="btn">Log In</button>
                </div>
            </div>
            <div>
                <h1 class="text-center text-white">Sign Up</h1>
                <div class="input_div" id="signUp">
                    <input type="text" name="name" placeholder="Name" class="input">
                    <input type="text" name="username" placeholder="Username" class="input">
                    <input type="text" name="password" placeholder="Password" class="input">
                    <input type="text" name="re_password" placeholder="Re-type Password" class="input">
                    <button id="signUpBtn" class="btn">Sign Up</button>
                </div>
            </div>
        </div>
    </main>
    <script src="./scripts/home_script.js"></script>
</body>
</html>